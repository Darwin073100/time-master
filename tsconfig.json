{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "declaration": true,           // Genera los archivos .d.ts para el autocompletado
    "outDir": "./dist", 
    "rootDir": "./",           // Carpeta donde se guardará el código compilado
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/*"]
}